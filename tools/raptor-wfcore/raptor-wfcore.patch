+static void wfcore_set_key(int scancode, bool pressed)
+{
+    if (scancode <= 0 || scancode >= 256)
+        return;
+
+    keyboard[scancode] = pressed ? 1 : 0;
+    if (pressed)
+    {
+        kbd_ack = 1;
+        lastscan = scancode;
+    }
+}
+
+static void wfcore_apply_buttons(uint32_t buttons)
+{
+    uint32_t pressed = buttons & ~wfcore_last_buttons;
+    wfcore_set_key(SC_ESC, (buttons & (1u << 0)) != 0);
+    wfcore_set_key(SC_UP, (buttons & (1u << 1)) != 0);
+    wfcore_set_key(SC_DOWN, (buttons & (1u << 2)) != 0);
+    wfcore_set_key(SC_LEFT, (buttons & (1u << 3)) != 0);
+    wfcore_set_key(SC_RIGHT, (buttons & (1u << 4)) != 0);
+    wfcore_set_key(SC_ENTER, (buttons & (1u << 5)) != 0);
+    wfcore_set_key(SC_CTRL, (buttons & (1u << 6)) != 0);
+    wfcore_set_key(SC_ALT, (buttons & (1u << 7)) != 0);
+    wfcore_set_key(SC_SPACE, (buttons & ((1u << 8) | (1u << 10))) != 0);
+    wfcore_set_key(SC_RIGHT_SHIFT, (buttons & (1u << 9)) != 0);
+    wfcore_set_key(SC_ENTER, (buttons & ((1u << 5) | (1u << 11))) != 0);
+
+    if ((pressed & (1u << 0)) != 0) lastscan = SC_ESC;
+    if ((pressed & (1u << 1)) != 0) lastscan = SC_UP;
+    if ((pressed & (1u << 2)) != 0) lastscan = SC_DOWN;
+    if ((pressed & (1u << 3)) != 0) lastscan = SC_LEFT;
+    if ((pressed & (1u << 4)) != 0) lastscan = SC_RIGHT;
+    if ((pressed & (1u << 5)) != 0) lastscan = SC_ENTER;
+    if ((pressed & (1u << 6)) != 0) lastscan = SC_CTRL;
+    if ((pressed & (1u << 7)) != 0) lastscan = SC_ALT;
+    if ((pressed & (1u << 8)) != 0) lastscan = SC_SPACE;
+    if ((pressed & (1u << 9)) != 0) lastscan = SC_RIGHT_SHIFT;
+    if ((pressed & (1u << 10)) != 0) lastscan = SC_SPACE;
+    if ((pressed & (1u << 11)) != 0) lastscan = SC_ENTER;
+    wfcore_last_buttons = buttons;
+}
+
+static void wfcore_poll_input(void)
+{
+    if (wfcore_socket_fd < 0)
+        return;
+
+    for (;;)
+    {
+        if (wfcore_input_buffer_used == sizeof(wfcore_input_buffer))
+        {
+            wfcore_input_buffer_used = 0;
+        }
+
+        ssize_t count = recv(
+            wfcore_socket_fd,
+            wfcore_input_buffer + wfcore_input_buffer_used,
+            sizeof(wfcore_input_buffer) - wfcore_input_buffer_used,
+            MSG_DONTWAIT);
+        if (count < 0 && (errno == EAGAIN || errno == EWOULDBLOCK))
+            break;
+        if (count <= 0)
+            break;
+        wfcore_input_buffer_used += (size_t)count;
+    }
+
+    size_t offset = 0;
+    while (wfcore_input_buffer_used - offset >= 32)
+    {
+        const uint8_t *header = wfcore_input_buffer + offset;
+        if (memcmp(header, "WFIN", 4) == 0)
+        {
+            uint32_t buttons;
+            memcpy(&buttons, header + 8, sizeof(buttons));
+            wfcore_apply_buttons(buttons);
+            offset += 32;
+            continue;
+        }
+        offset++;
+    }
+
+    if (offset > 0)
+    {
+        memmove(wfcore_input_buffer, wfcore_input_buffer + offset, wfcore_input_buffer_used - offset);
+        wfcore_input_buffer_used -= offset;
+    }
+}
+
+static void wfcore_send_frame(void)
+{
+    if (wfcore_socket_fd < 0 || wfcore_frame == NULL || screenbuffer == NULL)
+        return;
+
+    if (palette_to_set)
+    {
+        SDL_SetPaletteColors(screenbuffer->format->palette, palette, 0, 256);
+        palette_to_set = false;
+    }
+
+    const uint8_t *pixels = (const uint8_t *)screenbuffer->pixels;
+    for (int y = 0; y < SCREENHEIGHT; y++)
+    {
+        const uint8_t *row = pixels + y * screenbuffer->pitch;
+        for (int x = 0; x < SCREENWIDTH; x++)
+        {
+            SDL_Color color = palette[row[x]];
+            wfcore_frame[y * SCREENWIDTH + x] =
+                0xff000000u |
+                ((uint32_t)color.r << 16) |
+                ((uint32_t)color.g << 8) |
+                (uint32_t)color.b;
+        }
+    }
+
+    uint8_t header[32] = {
+        0x57, 0x46, 0x45, 0x58,
+        (uint8_t)SCREENWIDTH, (uint8_t)(SCREENWIDTH >> 8), 0, 0,
+        (uint8_t)SCREENHEIGHT, (uint8_t)(SCREENHEIGHT >> 8), 0, 0,
+        (uint8_t)SCREENWIDTH, (uint8_t)(SCREENWIDTH >> 8), 0, 0,
+    };
+    int32_t byte_count = SCREENWIDTH * SCREENHEIGHT * (int)sizeof(*wfcore_frame);
+    memcpy(header + 16, &wfcore_frame_index, sizeof(wfcore_frame_index));
+    memcpy(header + 24, &byte_count, sizeof(byte_count));
+
+    if (!wfcore_write_all(wfcore_socket_fd, header, sizeof(header)) ||
+        !wfcore_write_all(wfcore_socket_fd, wfcore_frame, (size_t)byte_count))
+    {
+        close(wfcore_socket_fd);
+        wfcore_socket_fd = -1;
+        return;
+    }
+    wfcore_frame_index++;
+}
+
+static bool wfcore_write_all(int fd, const void *buffer, size_t size)
+{
+    const uint8_t *bytes = (const uint8_t *)buffer;
+    while (size > 0)
+    {
+        ssize_t written = send(fd, bytes, size, MSG_NOSIGNAL);
+        if (written < 0 && (errno == EAGAIN || errno == EWOULDBLOCK))
+        {
+            SDL_Delay(1);
+            continue;
+        }
+        if (written <= 0)
+            return false;
+        bytes += written;
+        size -= (size_t)written;
+    }
+    return true;
+}
