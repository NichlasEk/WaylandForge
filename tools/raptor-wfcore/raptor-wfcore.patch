+static void wfcore_set_key(int scancode, bool pressed)
+{
+    if (scancode <= 0 || scancode >= 256)
+        return;
+
+    keyboard[scancode] = pressed ? 1 : 0;
+    if (pressed)
+    {
+        kbd_ack = 1;
+        lastscan = scancode;
+        lastascii = wfcore_scancode_to_ascii(scancode);
+    }
+}
+
+static void wfcore_apply_buttons(uint32_t buttons)
+{
+    uint32_t pressed = buttons & ~wfcore_last_buttons;
+    bool menu_mode = g_drawcursor != 0;
+    if (textmode)
+    {
+        wfcore_release_action_keys();
+        wfcore_action_pointer_buttons = 0;
+        if ((buttons & ((1u << 5) | (1u << 6) | (1u << 11))) != 0)
+            wfcore_action_pointer_buttons |= 1u;
+        if ((buttons & (1u << 7)) != 0)
+            wfcore_action_pointer_buttons |= 2u;
+        wfcore_last_buttons = buttons;
+        return;
+    }
+
+    // WaylandForge owns window/session exit; keep Raptor ESC from dropping to DOS.
+    wfcore_set_key(SC_ESC, false);
+    wfcore_set_key(SC_UP, (buttons & (1u << 1)) != 0);
+    wfcore_set_key(SC_DOWN, (buttons & (1u << 2)) != 0);
+    wfcore_set_key(SC_LEFT, (buttons & (1u << 3)) != 0);
+    wfcore_set_key(SC_RIGHT, (buttons & (1u << 4)) != 0);
+
+    if (menu_mode)
+    {
+        wfcore_set_key(SC_ENTER, (buttons & ((1u << 5) | (1u << 6) | (1u << 11))) != 0);
+        wfcore_set_key(SC_CTRL, false);
+        wfcore_set_key(SC_ALT, false);
+        wfcore_set_key(SC_SPACE, false);
+        wfcore_set_key(SC_RIGHT_SHIFT, false);
+        wfcore_set_key(SC_P, false);
+        wfcore_action_pointer_buttons = 0;
+        if ((buttons & ((1u << 5) | (1u << 6) | (1u << 11))) != 0)
+            wfcore_action_pointer_buttons |= 1u;
+        if ((buttons & (1u << 7)) != 0)
+            wfcore_action_pointer_buttons |= 2u;
+    }
+    else
+    {
+        wfcore_set_key(SC_ENTER, false);
+        wfcore_set_key(SC_CTRL, (buttons & (1u << 6)) != 0);
+        wfcore_set_key(SC_ALT, (buttons & (1u << 7)) != 0);
+        wfcore_set_key(SC_SPACE, (buttons & ((1u << 8) | (1u << 10))) != 0);
+        wfcore_set_key(SC_RIGHT_SHIFT, (buttons & (1u << 9)) != 0);
+        wfcore_set_key(SC_P, (buttons & (1u << 5)) != 0);
+        wfcore_action_pointer_buttons = 0;
+    }
+
+    if ((pressed & (1u << 1)) != 0) lastscan = SC_UP;
+    if ((pressed & (1u << 2)) != 0) lastscan = SC_DOWN;
+    if ((pressed & (1u << 3)) != 0) lastscan = SC_LEFT;
+    if ((pressed & (1u << 4)) != 0) lastscan = SC_RIGHT;
+    if (menu_mode)
+    {
+        if ((pressed & ((1u << 5) | (1u << 6) | (1u << 11))) != 0) lastscan = SC_ENTER;
+    }
+    else
+    {
+        if ((pressed & (1u << 5)) != 0) lastscan = SC_P;
+        if ((pressed & (1u << 6)) != 0) lastscan = SC_CTRL;
+        if ((pressed & (1u << 7)) != 0) lastscan = SC_ALT;
+        if ((pressed & (1u << 8)) != 0) lastscan = SC_SPACE;
+        if ((pressed & (1u << 9)) != 0) lastscan = SC_RIGHT_SHIFT;
+        if ((pressed & (1u << 10)) != 0) lastscan = SC_SPACE;
+    }
+    wfcore_last_buttons = buttons;
+}
+
+static void wfcore_poll_input(void)
+{
+    if (wfcore_socket_fd < 0)
+        return;
+
+    for (;;)
+    {
+        if (wfcore_input_buffer_used == sizeof(wfcore_input_buffer))
+        {
+            wfcore_input_buffer_used = 0;
+        }
+
+        ssize_t count = recv(
+            wfcore_socket_fd,
+            wfcore_input_buffer + wfcore_input_buffer_used,
+            sizeof(wfcore_input_buffer) - wfcore_input_buffer_used,
+            MSG_DONTWAIT);
+        if (count < 0 && (errno == EAGAIN || errno == EWOULDBLOCK))
+            break;
+        if (count <= 0)
+            break;
+        wfcore_input_buffer_used += (size_t)count;
+    }
+
+    size_t offset = 0;
+    while (wfcore_input_buffer_used - offset >= 32)
+    {
+        const uint8_t *header = wfcore_input_buffer + offset;
+        if (memcmp(header, "WFIN", 4) == 0)
+        {
+            int32_t packet_length;
+            uint32_t buttons;
+            uint32_t raw_key;
+            uint32_t raw_state;
+            memcpy(&packet_length, header + 4, sizeof(packet_length));
+            if (packet_length < 32 || packet_length > 256)
+            {
+                offset++;
+                continue;
+            }
+            if (wfcore_input_buffer_used - offset < (size_t)packet_length)
+            {
+                break;
+            }
+            memcpy(&buttons, header + 8, sizeof(buttons));
+            memcpy(&raw_key, header + 12, sizeof(raw_key));
+            memcpy(&raw_state, header + 28, sizeof(raw_state));
+            wfcore_apply_buttons(buttons);
+            if (packet_length >= 48)
+            {
+                int32_t pointer_x;
+                int32_t pointer_y;
+                uint32_t pointer_buttons;
+                uint32_t pointer_inside;
+                memcpy(&pointer_x, header + 32, sizeof(pointer_x));
+                memcpy(&pointer_y, header + 36, sizeof(pointer_y));
+                memcpy(&pointer_buttons, header + 40, sizeof(pointer_buttons));
+                memcpy(&pointer_inside, header + 44, sizeof(pointer_inside));
+                wfcore_apply_pointer(pointer_x, pointer_y, pointer_buttons, pointer_inside != 0);
+            }
+            int scancode = wfcore_raw_key_to_scancode(raw_key);
+            if (scancode != SC_NONE)
+            {
+                wfcore_set_key(scancode, raw_state != 0);
+            }
+            offset += (size_t)packet_length;
+            continue;
+        }
+        offset++;
+    }
+
+    if (offset > 0)
+    {
+        memmove(wfcore_input_buffer, wfcore_input_buffer + offset, wfcore_input_buffer_used - offset);
+        wfcore_input_buffer_used -= offset;
+    }
+}
+
+static void wfcore_apply_pointer(int32_t x, int32_t y, uint32_t buttons, bool inside)
+{
+    bool menu_pointer_move = g_drawcursor && (wfcore_last_buttons & ((1u << 1) | (1u << 2) | (1u << 3) | (1u << 4))) != 0;
+    int old_x = cur_mx;
+    int old_y = cur_my;
+    if (inside && !menu_pointer_move)
+    {
+        if (x < 0) x = 0;
+        if (x >= SCREENWIDTH) x = SCREENWIDTH - 1;
+        if (y < 0) y = 0;
+        if (y >= SCREENHEIGHT) y = SCREENHEIGHT - 1;
+        cur_mx = x;
+        cur_my = y;
+    }
+
+    if (menu_pointer_move)
+        wfcore_move_menu_pointer(wfcore_last_buttons);
+
+    if (old_x != cur_mx || old_y != cur_my)
+        PTR_SetUpdateFlag();
+
+    uint32_t effective_buttons = buttons | wfcore_action_pointer_buttons;
+    uint32_t pressed = effective_buttons & ~wfcore_last_pointer_buttons;
+    mouseb1 = (effective_buttons & 1u) != 0 ? 1 : 0;
+    mouseb2 = (effective_buttons & 2u) != 0 ? 2 : 0;
+    mouseb3 = (effective_buttons & 4u) != 0 ? 4 : 0;
+    if ((pressed & 1u) != 0) mouse_b1_ack = 1;
+    if ((pressed & 2u) != 0) mouse_b2_ack = 1;
+    if ((pressed & 4u) != 0) mouse_b3_ack = 1;
+    wfcore_last_pointer_buttons = effective_buttons;
+}
+
+static void wfcore_move_menu_pointer(uint32_t buttons)
+{
+    int step = (buttons & (1u << 9)) != 0 ? 8 : 4;
+    if ((buttons & (1u << 3)) != 0) cur_mx -= step;
+    if ((buttons & (1u << 4)) != 0) cur_mx += step;
+    if ((buttons & (1u << 1)) != 0) cur_my -= step;
+    if ((buttons & (1u << 2)) != 0) cur_my += step;
+    if (cur_mx < 0) cur_mx = 0;
+    if (cur_mx >= SCREENWIDTH) cur_mx = SCREENWIDTH - 1;
+    if (cur_my < 0) cur_my = 0;
+    if (cur_my >= SCREENHEIGHT) cur_my = SCREENHEIGHT - 1;
+}
+
+static void wfcore_release_action_keys(void)
+{
+    wfcore_set_key(SC_ESC, false);
+    wfcore_set_key(SC_UP, false);
+    wfcore_set_key(SC_DOWN, false);
+    wfcore_set_key(SC_LEFT, false);
+    wfcore_set_key(SC_RIGHT, false);
+    wfcore_set_key(SC_ENTER, false);
+    wfcore_set_key(SC_CTRL, false);
+    wfcore_set_key(SC_ALT, false);
+    wfcore_set_key(SC_SPACE, false);
+    wfcore_set_key(SC_RIGHT_SHIFT, false);
+    wfcore_set_key(SC_P, false);
+}
+
+static int wfcore_scancode_to_ascii(int scancode)
+{
+    bool shifted = keyboard[SC_LEFT_SHIFT] || keyboard[SC_RIGHT_SHIFT] || capslock;
+    switch (scancode)
+    {
+    case SC_A: return shifted ? 'A' : 'a';
+    case SC_B: return shifted ? 'B' : 'b';
+    case SC_C: return shifted ? 'C' : 'c';
+    case SC_D: return shifted ? 'D' : 'd';
+    case SC_E: return shifted ? 'E' : 'e';
+    case SC_F: return shifted ? 'F' : 'f';
+    case SC_G: return shifted ? 'G' : 'g';
+    case SC_H: return shifted ? 'H' : 'h';
+    case SC_I: return shifted ? 'I' : 'i';
+    case SC_J: return shifted ? 'J' : 'j';
+    case SC_K: return shifted ? 'K' : 'k';
+    case SC_L: return shifted ? 'L' : 'l';
+    case SC_M: return shifted ? 'M' : 'm';
+    case SC_N: return shifted ? 'N' : 'n';
+    case SC_O: return shifted ? 'O' : 'o';
+    case SC_P: return shifted ? 'P' : 'p';
+    case SC_Q: return shifted ? 'Q' : 'q';
+    case SC_R: return shifted ? 'R' : 'r';
+    case SC_S: return shifted ? 'S' : 's';
+    case SC_T: return shifted ? 'T' : 't';
+    case SC_U: return shifted ? 'U' : 'u';
+    case SC_V: return shifted ? 'V' : 'v';
+    case SC_W: return shifted ? 'W' : 'w';
+    case SC_X: return shifted ? 'X' : 'x';
+    case SC_Y: return shifted ? 'Y' : 'y';
+    case SC_Z: return shifted ? 'Z' : 'z';
+    case SC_SPACE: return ' ';
+    case SC_BACKSPACE: return 0x08;
+    case SC_ENTER: return 0x0d;
+    case SC_1: return shifted ? '!' : '1';
+    case SC_2: return shifted ? '@' : '2';
+    case SC_3: return shifted ? '#' : '3';
+    case SC_4: return shifted ? '$' : '4';
+    case SC_5: return shifted ? '%' : '5';
+    case SC_6: return shifted ? '^' : '6';
+    case SC_7: return shifted ? '&' : '7';
+    case SC_8: return shifted ? '*' : '8';
+    case SC_9: return shifted ? '(' : '9';
+    case SC_0: return shifted ? ')' : '0';
+    case SC_MINUS: return shifted ? '_' : '-';
+    default: return SC_NONE;
+    }
+}
+
+static int wfcore_raw_key_to_scancode(uint32_t raw_key)
+{
+    if (raw_key == 0 || raw_key == UINT32_MAX)
+        return SC_NONE;
+
+    switch (raw_key)
+    {
+    case 1: return SC_NONE;
+    case 103: return SC_UP;
+    case 108: return SC_DOWN;
+    case 105: return SC_LEFT;
+    case 106: return SC_RIGHT;
+    default:
+        break;
+    }
+
+    return raw_key < 256 ? (int)raw_key : SC_NONE;
+}
+
+static void wfcore_send_frame(void)
+{
+    if (wfcore_socket_fd < 0 || wfcore_frame == NULL || screenbuffer == NULL)
+        return;
+
+    if (palette_to_set)
+    {
+        SDL_SetPaletteColors(screenbuffer->format->palette, palette, 0, 256);
+        palette_to_set = false;
+    }
+
+    const uint8_t *pixels = (const uint8_t *)screenbuffer->pixels;
+    for (int y = 0; y < SCREENHEIGHT; y++)
+    {
+        const uint8_t *row = pixels + y * screenbuffer->pitch;
+        for (int x = 0; x < SCREENWIDTH; x++)
+        {
+            SDL_Color color = palette[row[x]];
+            wfcore_frame[y * SCREENWIDTH + x] =
+                0xff000000u |
+                ((uint32_t)color.r << 16) |
+                ((uint32_t)color.g << 8) |
+                (uint32_t)color.b;
+        }
+    }
+
+    uint8_t header[32] = {
+        0x57, 0x46, 0x45, 0x58,
+        (uint8_t)SCREENWIDTH, (uint8_t)(SCREENWIDTH >> 8), 0, 0,
+        (uint8_t)SCREENHEIGHT, (uint8_t)(SCREENHEIGHT >> 8), 0, 0,
+        (uint8_t)SCREENWIDTH, (uint8_t)(SCREENWIDTH >> 8), 0, 0,
+    };
+    int32_t byte_count = SCREENWIDTH * SCREENHEIGHT * (int)sizeof(*wfcore_frame);
+    memcpy(header + 16, &wfcore_frame_index, sizeof(wfcore_frame_index));
+    memcpy(header + 24, &byte_count, sizeof(byte_count));
+
+    if (!wfcore_write_all(wfcore_socket_fd, header, sizeof(header)) ||
+        !wfcore_write_all(wfcore_socket_fd, wfcore_frame, (size_t)byte_count))
+    {
+        close(wfcore_socket_fd);
+        wfcore_socket_fd = -1;
+        return;
+    }
+    wfcore_frame_index++;
+}
+
+static bool wfcore_write_all(int fd, const void *buffer, size_t size)
+{
+    const uint8_t *bytes = (const uint8_t *)buffer;
+    while (size > 0)
+    {
+        ssize_t written = send(fd, bytes, size, MSG_NOSIGNAL);
+        if (written < 0 && (errno == EAGAIN || errno == EWOULDBLOCK))
+        {
+            SDL_Delay(1);
+            continue;
+        }
+        if (written <= 0)
+            return false;
+        bytes += written;
+        size -= (size_t)written;
+    }
+    return true;
+}
