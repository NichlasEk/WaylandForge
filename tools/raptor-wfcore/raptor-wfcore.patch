+static void wfcore_connect(void)
+{
+    const char *socket_path = getenv("WFCORE_SOCKET");
+    wfcore_mode = getenv("RAPTOR_WFCORE") != NULL;
+    if (!wfcore_mode || socket_path == NULL || socket_path[0] == '\0')
+        return;
+
+    wfcore_socket_fd = socket(AF_UNIX, SOCK_STREAM, 0);
+    if (wfcore_socket_fd < 0)
+    {
+        fprintf(stderr, "warning: failed to create WF core socket: %s\n", strerror(errno));
+        return;
+    }
+
+    struct sockaddr_un addr;
+    memset(&addr, 0, sizeof(addr));
+    addr.sun_family = AF_UNIX;
+    snprintf(addr.sun_path, sizeof(addr.sun_path), "%s", socket_path);
+    if (connect(wfcore_socket_fd, (struct sockaddr *)&addr, sizeof(addr)) != 0)
+    {
+        fprintf(stderr, "warning: failed to connect WF core socket '%s': %s\n", socket_path, strerror(errno));
+        close(wfcore_socket_fd);
+        wfcore_socket_fd = -1;
+        return;
+    }
+
+    int flags = fcntl(wfcore_socket_fd, F_GETFL, 0);
+    if (flags >= 0)
+        fcntl(wfcore_socket_fd, F_SETFL, flags | O_NONBLOCK);
+
+    fprintf(stderr, "WF core socket connected: %s\n", socket_path);
+}
+
+static void wfcore_disconnect(void)
+{
+    if (wfcore_socket_fd >= 0)
+    {
+        close(wfcore_socket_fd);
+        wfcore_socket_fd = -1;
+    }
+    free(wfcore_frame);
+    wfcore_frame = NULL;
+    wfcore_input_buffer_used = 0;
+}
